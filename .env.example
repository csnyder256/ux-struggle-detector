# Copy this file to .env and fill in real values. Never commit .env.

# --- Access mode ---
# "false" = open-access dev mode (no sign-in, singleton Demo Workspace org).
REQUIRE_AUTH="false"
# "true"/"1" = /api/events rejects batches without a valid ck_ ingest key.
REQUIRE_INGEST_KEY="false"
# Set by the runtime; only override it if you know why. development | production | test
# NODE_ENV="development"

# --- Database ---
# Postgres connection string read by Prisma (prisma/schema.prisma).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clarus_heal?schema=public"

# --- Auth.js (NextAuth v5) ---
# Session-signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-32-random-bytes-base64"
# Public base URL of this deployment; also used to build the SDK snippet shown in the dashboard.
AUTH_URL="http://localhost:3000"

# --- Magic-link email (SMTP), only needed when REQUIRE_AUTH=true ---
# SMTP hostname of your mail provider.
EMAIL_SERVER_HOST="smtp.example.com"
# SMTP port (587 for STARTTLS, 465 for implicit TLS).
EMAIL_SERVER_PORT="587"
# SMTP username.
EMAIL_SERVER_USER="your-smtp-username-here"
# SMTP password or provider API key. Use a provider token, not a personal mailbox password.
EMAIL_SERVER_PASSWORD="your-smtp-password-here"
# From address on magic-link emails.
EMAIL_FROM="noreply@example.com"

# --- Key encryption master key (AES-256-GCM) ---
# Encrypts customer-supplied LLM provider keys at rest. 32 random bytes, base64.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KEY_ENCRYPTION_KEY="replace-with-32-random-bytes-base64"

# --- GitHub App (only for the "Connect GitHub" onboarding path) ---
# See GITHUB_SETUP.md. Leave blank to disable that path entirely.
# App slug from github.com/apps/<slug>
GITHUB_APP_NAME=""
# Numeric App ID from the app settings page.
GITHUB_APP_ID=""
# OAuth client id, starts with "Iv1." or "Iv23."
GITHUB_APP_CLIENT_ID=""
# OAuth client secret generated on the app page.
GITHUB_APP_CLIENT_SECRET="your-github-app-client-secret-here"
# Entire .pem private key, base64-encoded onto a single line.
GITHUB_APP_PRIVATE_KEY="your-base64-encoded-pem-here"
# HMAC secret that must match the webhook secret configured in the GitHub UI.
GITHUB_APP_WEBHOOK_SECRET="your-webhook-secret-here"

# --- Cron worker auth ---
# Bearer secret required by /api/cron/{detect-struggles,compute-baselines,precompute-interventions}.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-cron-secret-here"
